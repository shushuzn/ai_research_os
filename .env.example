# ai_research_os — environment variables
# Copy this file to .env and fill in values.
# All settings are optional; defaults match the historical hardcoded values.

# ── Embedding ────────────────────────────────────────────────────────────────
# Embedding vector dimension (nomic-embed-text uses 768)
# AIROS_EMBEDDING_DIM=768

# ── HTTP cache ───────────────────────────────────────────────────────────────
# How long cached arXiv / Crossref API responses live, in seconds
# AIROS_CACHE_TTL_SECONDS=86400

# ── LLM cost table ───────────────────────────────────────────────────────────
# Override or extend the built-in token-price table.
# Format: model_prefix:input_per_1M:output_per_1M, comma-separated.
# Unrecognised models fall back to the "default" entry (1.0, 4.0).
# Example (adds a new entry):
# AIROS_MODEL_PRICES=my-model:0.5:2.0
#
# The built-in table includes: gpt-4o, gpt-4o-mini, gpt-4-turbo,
# gpt-3.5-turbo, o1-preview, o1-mini, qwen3.5-plus, qwen3.5, qwen2.5,
# deepseek-chat, claude-3-5-sonnet, claude-3-5-haiku

# ── Default LLM models ───────────────────────────────────────────────────────
# AIROS_DEFAULT_MODEL_CLI=qwen3.5-plus      # used by cli.py
# AIROS_DEFAULT_MODEL_RESEARCH=gpt-4o-mini  # used by research_loop/__init__.py

# ── Author-parsing cache ─────────────────────────────────────────────────────
# Maxsize for the LRU cache that deduplicates JSON-author parsing
# AIROS_PARSE_AUTHORS_CACHE_SIZE=4096
