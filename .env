# MiniMax M2.7 高速模型
OPENAI_API_KEY=sk-cp-zNNt30MolJOgSwdsdgA8BJbLoKmiV3Zttz_IgZkapeyjoPPq-qYFSw-XiMZIIUyeH4PTB4Y86QXu_wKR8JvmZ9PbkkMmMwDTC6QgHznXopDTl0nBZ9AQHQ8
AIROS_DEFAULT_OPENAI_BASE_URL=https://api.minimax.chat/v1

# ── 默认模型 ─────────────────────────────────────────────────────────────────
